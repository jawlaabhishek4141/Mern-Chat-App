# Port the Express + Socket.io server listens on
PORT=5000

# Node environment: development | production
NODE_ENV=development

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/mern_chat
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mern_chat
MONGO_URI=mongodb://127.0.0.1:27017/mern_chat

# Secret used to sign JWTs - replace with a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Comma-separated list of origins allowed to call the API / connect via Socket.io
CLIENT_ORIGIN=http://localhost:5173

# General API rate limit (requests per window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
